# =============================================================================
# Doppelvoice — Doubao Seed LiveInterpret 2.0 credentials
# 火山引擎豆包同传 2.0 密钥
# =============================================================================
#
# Where to find them / 在哪获取:
#   https://console.volcengine.com/speech/app
#   → 豆包语音 (Doubao Voice)
#   → 同声传译 2.0 (Simultaneous Interpretation 2.0)
#   → 应用管理 (App Management)
#
# Field names map / 字段对应关系（容易填错，注意区分）:
#   DOUBAO_APP_KEY    = 控制台显示的 "App Key" 字段（不是 Access Token / API Key）
#                       Console field: "App Key" (NOT Access Token / API Key)
#   DOUBAO_ACCESS_KEY = 控制台显示的 "Access Token" 字段（字母数字混合）
#                       Console field: "Access Token" (alphanumeric)
#   DOUBAO_RESOURCE_ID 已预填，除非字节官方更名否则别动
#                       Pre-filled; do not change unless ByteDance renames the service
#
DOUBAO_APP_KEY=
DOUBAO_ACCESS_KEY=
DOUBAO_RESOURCE_ID=volc.service_type.10053

# -----------------------------------------------------------------------------
# Optional overrides — uncomment to change defaults
# 可选覆盖项 —— 取消注释行首 # 来生效
# -----------------------------------------------------------------------------

# Source / target language. Choose from 9 codes:
#   zh / en / ja / id / es / pt / de / fr / zhen
# 'zhen' = bilingual ZH⇄EN auto mode (set BOTH source and target to 'zhen').
# 源/目标语言。zhen=中英互译自动模式（两端都填 zhen）。
# SOURCE_LANG=zh
# TARGET_LANG=en

# Translation mode: s2s = speech→speech (default), s2t = speech→text only
# 翻译模式：s2s=语音到语音（默认），s2t=语音到文本
# MODE=s2s

# Server-side denoise. 0 = off (default — keeps your voice timbre details for
# better cloning). 1 = on (cleaner input but flattens unique characteristics).
# 服务端降噪。0=关（默认，保留音色细节让克隆更像本人）/ 1=开（输入更干净但克隆变平）
# DENOISE=0

# Audio device substring matchers. Leave empty for system defaults.
# 音频设备名子串匹配。留空使用系统默认。
# INPUT_DEVICE=
# OUTPUT_DEVICE=CABLE Input

# Log verbosity: DEBUG / INFO / WARNING / ERROR
# 日志级别：DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# Debug-only flags — keep OFF unless troubleshooting (writes raw audio /
# subtitles to disk; voice content will be persisted!).
# 调试开关 —— 排查问题时才开，会把语音/字幕原文落盘
# DUMP_AUDIO=0
# LOG_SUBTITLE=0
